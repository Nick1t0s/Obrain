# ==============================================================================
# 🤖 TELEGRAM BOT CONFIGURATION
# ==============================================================================
# Токен авторизации бота. Получите его у @BotFather в Telegram.
# Никогда не передавайте этот токен третьим лицам.
BOT_TOKEN="ВАШ ТОКЕН БОТА"

# ID пользователя в Telegram, который будет получать уведомления и логи.
# Узнать свой ID можно через бота @userinfobot или @getmyid_bot.
TELEGRAM_USER_ID="7882141240"

# ID чата для дублирования логов работы бота.
# Может совпадать с TELEGRAM_USER_ID или указывать на отдельный канал/чат для логов.
TELEGRAM_LOG_CHAT_ID="7882141240"


# ==============================================================================
# 📁 OBSIDIAN VAULT PATHS
# ==============================================================================
# Пути к файлам и папкам вашего хранилища Obsidian.
# Используйте абсолютные пути. Если в путях есть пробелы (как в "My Vault"),
# кавычки обязательны. Убедитесь, что у скрипта есть права на запись в эти папки.

# Путь к файлу для хранения необработанных ("сырых") данных/заметок.
PATH_TO_RAW="/home/nik/Obsidian_sync/My Vault/Заметки/raw_data.md"

# Путь к папке для ежедневных заметок (Журнал по дням).
# Сюда бот может создавать или дописывать файлы с ежедневными записями.
PATH_TO_JOURNAL="/home/nik/Obsidian_sync/My Vault/Заметки/Журнал по дням"

# Путь к папке для хранения сгенерированных саммари (кратких содержаний).
PATH_TO_SUMMARY="/home/nik/Obsidian_sync/My Vault/Заметки/Суммари"


# ==============================================================================
# 🧠 OLLAMA & LLM SETTINGS
# ==============================================================================
# Базовый URL API локального сервера Ollama.
# Стандартный адрес: http://127.0.0.1:11434
OLLAMA_BASE_URL="http://127.0.0.1:11434"

# Название модели для очистки, структурирования и первичной обработки текста.
# Формат: "имя_пользователя/имя_модели:тег" или просто "имя_модели:тег".
# Указанная модель: форк Qwen 3.5 Instruct с 9 млрд параметров.
OLLAMA_MODEL_CLEAN="frob/qwen3.5-instruct:9b" # qwen3.5:9b как вариант

# Название модели для генерации итоговых саммари и выводов.
# Можно использовать ту же модель, что и для очистки, или более "умную" для сложных задач.
OLLAMA_MODEL_SUMMARY="frob/qwen3.5-instruct:9b" # qwen3.5:9b как вариант

# Температура генерации (0.0 – 1.0).
# 0.3 — низкое значение для более детерминированных, точных и фактологических ответов.
# Повышение значения добавляет креативности, но увеличивает риск галлюцинаций.
LLM_TEMPERATURE="0.3"

# Таймаут ожидания ответа от LLM в секундах.
# Увеличьте значение, если модели требуется больше времени на размышления или генерацию длинных текстов.
LLM_TIMEOUT="120"

# Настройка Keep-Alive для модели в памяти Ollama (в минутах).
# "0" — выгружать модель из оперативной памяти сразу после завершения запроса (экономия ресурсов).
# "-1" — держать модель в памяти постоянно (быстрее ответ, но занимает VRAM/RAM).
OLLAMA_KEEP_ALIVE="0"  # Выгружать модель сразу после ответа


# ==============================================================================
# ⏰ SCHEDULED TASKS (Планировщик)
# ==============================================================================
# Время (в формате ЧЧ:ММ) для автоматической генерации дневного саммари.
DAILY_SUMMARY_TIME="23:30"

# День недели для еженедельного обзора (1 = Понедельник, 7 = Воскресенье).
WEEKLY_REVIEW_DAY="7"

# Число месяца для запуска ежемесячного обзора (1–31).
# Если в месяце меньше дней (например, 30 или 28), задача может быть пропущена или выполнена в последний день.
MONTHLY_REVIEW_DAY="31"


# ==============================================================================
# 📎 FILE & MEDIA PROCESSING
# ==============================================================================
# Максимальный размер файла (в мегабайтах), который бот примет для обработки.
# Ограничение защищает от перегрузки памяти при попытке обработать слишком большие файлы.
MAX_FILE_SIZE_MB="20"

# Название модели Whisper для транскрибации аудио/видео в текст.
# Варианты: "tiny", "base", "small", "medium", "large-v3" (наиболее точная, но требовательная).
# Убедитесь, что модель предварительно скачана в среде, где работает скрипт.
WHISPER_MODEL="large-v3"


# ==============================================================================
# 🌐 PROXY SETTINGS (для обхода замедления)
# ==============================================================================
# Настройки прокси-сервера для обхода блокировок или ограничений сети.

# Тип прокси-протокола.
# Допустимые значения: "socks5", "http", "https" или пустая строка "" для работы без прокси.
PROXY_TYPE="socks5"

# Хост (адрес) прокси-сервера.
# Для локальных приложений (Hiddify, v2ray и др.) обычно используется localhost.
PROXY_HOST="127.0.0.1"

# Порт прокси-сервера.
# Убедитесь, что порт совпадает с настройками вашего прокси-клиента (в конфиге указан 12334).
PROXY_PORT="12334"

# Данные для авторизации на прокси-сервере.
# Если прокси не требует логина и пароля, оставьте эти поля пустыми.
PROXY_LOGIN=""
PROXY_PASSWORD=""

# Таймауты для сетевых запросов (в секундах).
# Увеличенные значения помогают избежать разрывов соединения при нестабильном интернете или высоком пинге через прокси.

# Таймаут для обычных запросов к Telegram API.
TELEGRAM_TIMEOUT="30"

# Таймаут для Long Polling (длительного опроса) обновлений от Telegram.
# Должен быть достаточно большим (30–90 сек), чтобы сервер не разрывал соединение преждевременно.
TELEGRAM_LONG_POLLING_TIMEOUT="60"